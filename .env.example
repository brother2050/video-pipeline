# 环境变量示例
# 复制此文件为 .env 并填写实际值

# 服务端口
VP_HOST=0.0.0.0
VP_PORT=8000
VP_DEBUG=false

# 数据库（默认 SQLite，生产可切换 PostgreSQL）
VP_DATABASE_URL=sqlite+aiosqlite:///data/db/pipeline.db
# VP_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/videopipeline

# CORS 允许的前端地址
VP_CORS_ORIGINS=["http://localhost:5173"]

# 数据目录
VP_DATA_DIR=data

# 供应商 API Key（按需填写）
# VP_DEEPSEEK_API_KEY=
# VP_SILICONFLOW_API_KEY=
# VP_GEMINI_API_KEY=
# VP_GLM_API_KEY=
# VP_QWEN_API_KEY=
